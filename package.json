{
  "name": "nisaba",
  "version": "1.0.0",
  "description": "A WASM/C, MongoDB-driver-shaped embedded document database (CRUD, query operators, $regex, secondary/geo/text indexes, change streams), built on binjson and binjson-structures",
  "type": "module",
  "main": "src/db.js",
  "exports": {
    ".": "./src/db.js",
    "./remote": "./src/db-remote.js",
    "./wasm": "./wasm/nisaba-wasm.js",
    "./coordinator": "./src/db-coordinator.js"
  },
  "files": [
    "wasm",
    "bin",
    "src",
    "index.html"
  ],
  "bin": {
    "db": "bin/db.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.js",
    "build:wasm": "./wasm/build-wasm.sh",
    "prepack": "npm run build:wasm",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "database",
    "document-database",
    "embedded-database",
    "mongodb",
    "wasm",
    "opfs",
    "binjson"
  ],
  "author": "",
  "license": "BSD-2-Clause",
  "devDependencies": {
    "@vitest/browser": "^3.2.4",
    "node-opfs": "^1.2.0",
    "playwright": "^1.49.1",
    "vite": "^7.3.6",
    "vitest": "^3.2.4"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fs-ext@2.1.1": true
  }
}
